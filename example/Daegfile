# syntax=ghcr.io/yourname/daeg:latest
#
# Canonical Daegfile example — polyglot data science image.
#
# Graph:
#
#   ubuntu:24.04 (base)
#   ├── cuda-tools
#   ├── opencv
#   └── ffmpeg
#         ↓
#     MERGE → system-deps
#     ├── python-app
#     └── node-app
#           ↓
#       MERGE → final
#
# The first merge is messy: three apt installs collide in /usr/lib and
# /etc/ld.so.conf.d. We repair with ldconfig and discard build artifacts once,
# at the merge point, instead of in every branch.
#
# The second merge is clean: Python installs to /usr/local/lib/python3.12
# and Node installs to /app/ui/node_modules. No conflicts expected.
# With default=error, the build verifies this assertion at build time.

# ── shared base ────────────────────────────────────────────────────────────────
FROM ubuntu:24.04 AS base
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    tzdata \
    && rm -rf /var/lib/apt/lists/*

# ── system-level branches ──────────────────────────────────────────────────────
# Each branch installs one concern independently. They do not clean up after
# themselves — the merge will handle that once, below.

FROM base AS cuda-tools
RUN apt-get install -y nvidia-cuda-toolkit

FROM base AS opencv
RUN apt-get install -y libopencv-dev python3-opencv

FROM base AS ffmpeg
RUN apt-get install -y ffmpeg libavcodec-dev libavformat-dev

# ── merge system deps ──────────────────────────────────────────────────────────
# The three branches above all write to /usr/lib/x86_64-linux-gnu/ and
# /etc/ld.so.conf.d/. The content-hash check resolves shared deps silently.
# The only true conflict is /etc/ld.so.cache — each branch ran ldconfig
# independently and produced a partial cache. We repair it with ldconfig
# after the merge, then discard all apt artifacts once.
FROM MERGE(cuda-tools, opencv, ffmpeg)
RESOLVE WITH script ldconfig
RESOLVE WITH discard /var/lib/apt/lists /var/cache/apt /var/log /tmp
AS system-deps

# ── application-level branches ─────────────────────────────────────────────────
# These build on system-deps and install into non-overlapping paths.
# Python → /usr/local/lib/python3.12/
# Node   → /app/ui/node_modules/

FROM system-deps AS python-app
RUN apt-get install -y python3-pip python3-dev
RUN pip3 install --no-cache-dir torch numpy fastapi uvicorn

FROM system-deps AS node-app
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
RUN apt-get install -y nodejs
COPY ui/package.json /app/ui/package.json
RUN npm install --prefix /app/ui
COPY ui/ /app/ui/
RUN npx --prefix /app/ui vite build

# ── final merge ─────────────────────────────────────────────────────────────────
# No RESOLVE lines — we assert that python-app and node-app do not conflict.
# With default=error, BuildKit will fail the build if that assertion is wrong.
FROM MERGE(python-app, node-app)
AS final

WORKDIR /app
COPY server.py .
COPY --from=node-app /app/ui/dist /app/ui

EXPOSE 8000
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
